<idea-plugin>
    <id>com.github.dungphan.unityindex</id>
    <name>Unity Index MCP Server</name>
    <vendor email="dung.phanv@gmail.com" url="https://github.com/dungphan">dungphan</vendor>
    <description><![CDATA[
<p><b>Unity C# Codebase Index MCP Server</b> — exposes IDE code intelligence for Unity C# projects
to AI agents via the <a href="https://modelcontextprotocol.io">Model Context Protocol (MCP)</a>.</p>

<p>Provides semantic code navigation (find references, go to definition, symbol search, type hierarchy)
instead of raw text grep, dramatically reducing token usage and improving AI agent accuracy.</p>

<h3>Core Tools</h3>
<ul>
    <li><b>Find References</b> - Locate all usages of any symbol across your project</li>
    <li><b>Go to Definition</b> - Jump to symbol declarations instantly</li>
    <li><b>Symbol Search</b> - Find symbols by name</li>
    <li><b>Code Diagnostics</b> - Access errors, warnings, and available quick fixes</li>
    <li><b>File Structure</b> - View hierarchical file outline</li>
    <li><b>Type Hierarchy</b> - Explore class inheritance chains</li>
</ul>
]]>    </description>

    <!-- Rider dependency (required — this plugin only runs in Rider) -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.rider</depends>

    <resource-bundle>messages.McpBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Application-level MCP Server Service -->
        <applicationService serviceImplementation="com.github.dungphan.unityindex.server.McpServerService"/>

        <!-- Project-level Build Diagnostics Cache Service -->
        <projectService serviceImplementation="com.github.dungphan.unityindex.server.BuildDiagnosticsCacheService"/>

        <!-- Project-level diagnostics analysis service -->
        <projectService serviceImplementation="com.github.dungphan.unityindex.tools.intelligence.DiagnosticsAnalysisService"/>

        <!-- Day 7 — project-scoped snapshot cache + VFS listener for graph deltas -->
        <projectService serviceImplementation="com.github.dungphan.unityindex.graph.GraphSnapshotCache"/>

        <!-- Settings -->
        <applicationService serviceImplementation="com.github.dungphan.unityindex.settings.McpSettings"/>
        <applicationConfigurable id="unity-index-mcp.settings" displayName="Unity Index MCP Server" instance="com.github.dungphan.unityindex.settings.McpSettingsConfigurable"/>

        <!-- Startup Activity -->
        <postStartupActivity implementation="com.github.dungphan.unityindex.startup.McpServerStartupActivity"/>

        <!-- Notification Group -->
        <notificationGroup id="Unity Index MCP Server" displayType="BALLOON"/>

        <!-- Graph viewer tool window (Day 1: 3 hardcoded nodes via Sigma) -->
        <toolWindow id="Unity Index Graph"
                    anchor="right"
                    icon="AllIcons.Toolwindows.WebToolWindow"
                    factoryClass="com.github.dungphan.unityindex.graph.GraphToolWindowFactory"/>
    </extensions>

    <!-- Extension Point for Custom Tools -->
    <extensionPoints>
        <extensionPoint name="mcpTool" interface="com.github.dungphan.unityindex.tools.McpTool" dynamic="true"/>
    </extensionPoints>

    <actions>
        <!-- Day 11 Task 8 — offline graph browsing. Prompts for a JSON export and
             hands it to the Unity Index Graph tool window. -->
        <action id="UnityIndex.OpenGraphFromFile"
                class="com.github.dungphan.unityindex.graph.OpenGraphFromFileAction"
                text="Unity Index: Open Graph from File…"
                description="Load a previously exported unity-index graph JSON for offline browsing.">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
